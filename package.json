{
  "name": "operapyme-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev:backoffice": "npm run dev --workspace @operapyme/backoffice-pwa --",
    "build:backoffice": "npm run build --workspace @operapyme/backoffice-pwa",
    "typecheck:backoffice": "npm run typecheck --workspace @operapyme/backoffice-pwa",
    "test": "npm run test:unit && npm run test:integration && npm run test:contract",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "verify": "npm run typecheck:backoffice && npm run build:backoffice && npm run test && npm run test:e2e:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0",
    "vitest": "^2.1.9"
  }
}

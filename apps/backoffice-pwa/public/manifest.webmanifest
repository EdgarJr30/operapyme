{
  "name": "OperaPyme Backoffice",
  "short_name": "OperaPyme",
  "description": "Backoffice PWA para cotizaciones, gastos, reportes y operacion comercial de pymes.",
  "theme_color": "#f7f4ef",
  "background_color": "#f7f4ef",
  "display": "standalone",
